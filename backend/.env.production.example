# Produção - Gestor de Tarefas (Debian)
# Copiar para .env no servidor: cp .env.production.example .env

# Servidor
PORT=3001
NODE_ENV=production

# Banco de dados MariaDB (no próprio servidor ou remoto)
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://gestor:senha_forte_aqui@localhost:3306/gestor_tarefas"

# CORS - URL do frontend (domínio público onde o site será acessado)
# Se Nginx serve front e API no mesmo domínio, use uma única origem
CORS_ORIGIN="https://tarefas.seudominio.com"

# JWT (obrigatório em produção - gere um segredo forte)
# Exemplo: openssl rand -base64 32
JWT_SECRET="gere_um_segredo_longo_e_aleatorio_aqui"
JWT_EXPIRES_IN=8h

# SSH Tunnel - deixe vazio se o banco estiver no mesmo servidor
# SSH_HOST=
# SSH_PORT=22
# SSH_USER=
# SSH_PASSWORD=
# DB_HOST=localhost
# DB_PORT=3306
